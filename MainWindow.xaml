<Window x:Class="Marketing_Meetings_Summary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marketing Kickoff meeting Summary" Height="900" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Window.Resources>
        <!-- Modern Rounded Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="16" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded DatePicker matching text-field look -->
        <Style x:Key="RoundedDatePicker" TargetType="DatePicker">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox"
                                                   Grid.Column="0"
                                                   BorderThickness="0"
                                                   Background="Transparent"
                                                   Padding="8,0,2,0"
                                                   FontSize="12"
                                                   FontWeight="Normal"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"/>
                                <Button x:Name="PART_Button"
                                        Grid.Column="1"
                                        Focusable="False"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        VerticalAlignment="Stretch"
                                        HorizontalAlignment="Stretch">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <Canvas Width="14" Height="14"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                    <!-- Calendar outline -->
                                                    <Rectangle Canvas.Left="0" Canvas.Top="2"
                                                               Width="14" Height="12"
                                                               Stroke="#64748B" StrokeThickness="1"
                                                               Fill="White" RadiusX="1" RadiusY="1"/>
                                                    <!-- Header band -->
                                                    <Rectangle Canvas.Left="0" Canvas.Top="2"
                                                               Width="14" Height="4"
                                                               Fill="#94A3B8" RadiusX="1" RadiusY="1"/>
                                                    <!-- Cover bottom of header radius -->
                                                    <Rectangle Canvas.Left="0" Canvas.Top="4"
                                                               Width="14" Height="2"
                                                               Fill="#94A3B8"/>
                                                    <!-- Left tab -->
                                                    <Rectangle Canvas.Left="3" Canvas.Top="0"
                                                               Width="2" Height="5"
                                                               Fill="#64748B" RadiusX="1" RadiusY="1"/>
                                                    <!-- Right tab -->
                                                    <Rectangle Canvas.Left="9" Canvas.Top="0"
                                                               Width="2" Height="5"
                                                               Fill="#64748B" RadiusX="1" RadiusY="1"/>
                                                </Canvas>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       StaysOpen="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact rounded ComboBox matching text-field look (used for System Type row) -->
        <Style x:Key="CompactRoundedComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6,2,6,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{TemplateBinding SelectionBoxItem}"
                                               Margin="{TemplateBinding Padding}"
                                               Padding="0"
                                               FontSize="{TemplateBinding FontSize}"
                                               FontWeight="Normal"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               IsHitTestVisible="False"/>
                                    <Path Grid.Column="1"
                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="#64748B"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="0,1,4,0"/>
                                    <ToggleButton Grid.Column="0"
                                                  Grid.ColumnSpan="2"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Focusable="False">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="2"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.12" Color="#000000"/>
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- White ComboBox Style with full ControlTemplate -->
        <Style x:Key="WhiteComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="2,0,2,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{TemplateBinding SelectionBoxItem}"
                                               Margin="4,0,0,0"
                                               Padding="0"
                                               FontSize="{TemplateBinding FontSize}"
                                               FontWeight="Normal"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               IsHitTestVisible="False"/>
                                    <Path Grid.Column="1"
                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="#64748B"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="0,1,2,0"/>
                                    <ToggleButton Grid.Column="0"
                                                  Grid.ColumnSpan="2"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Focusable="False">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        CornerRadius="0"
                                        Padding="2"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.12" Color="#000000"/>
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Card Style -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Side Menu with Logo -->
        <Border Grid.Column="0" 
                Background="White" 
                CornerRadius="12" 
                Padding="16"
                Margin="0,0,16,0"
                BorderThickness="1"
                BorderBrush="#E2E8F0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.08" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <!-- Logo at top of side menu -->
                <Border Height="60" Margin="0,0,0,24" HorizontalAlignment="Center">
                    <Image Source="logo.png" Height="60" Stretch="Uniform"/>
                </Border>

                <!-- Overview Menu Item -->
                <Button x:Name="btnOverview"
                        Click="NavigateToSection"
                        Tag="0"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="10,8"
                        Margin="0,0,0,6"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏠" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Order Overview" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Configuration Menu Item -->
                <Button x:Name="btnConfiguration"
                        Click="NavigateToSection"
                        Tag="1"
                        Background="Transparent"
                        Foreground="#64748B"
                        BorderThickness="0"
                        Padding="10,8"
                        Margin="0,0,0,6"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Configuration" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Targets Menu Item -->
                <Button x:Name="btnTargets"
                        Click="NavigateToSection"
                        Tag="2"
                        Background="Transparent"
                        Foreground="#64748B"
                        BorderThickness="0"
                        Padding="10,8"
                        Margin="0,0,0,6"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎯" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Targets List" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Actions Menu Item -->
                <Button x:Name="btnActions"
                        Click="NavigateToSection"
                        Tag="3"
                        Background="Transparent"
                        Foreground="#64748B"
                        BorderThickness="0"
                        Padding="10,8"
                        Margin="0,0,0,6"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Questions/Notes" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Block Diagram Menu Item -->
                <Button x:Name="btnBlockDiagram"
                        Click="NavigateToSection"
                        Tag="4"
                        Background="Transparent"
                        Foreground="#64748B"
                        BorderThickness="0"
                        Padding="10,8"
                        Margin="0,0,0,6"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand"
                        IsEnabled="False"
                        Opacity="0.4">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔲" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="btnBlockDiagramText"
                                               Text="Block Diagram" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- Right Content Area - Two Separate Cards -->
        <StackPanel Grid.Column="1">
            <!-- Title and Buttons (No white card - on background) -->
            <Grid Margin="24,8,24,12">
                <Grid.ColumnDefinitions>
                    <!-- Title: auto-size so buttons sit right next to it -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="titleText"
                               Text="Marketing Kickoff Meeting Summary"
                               FontSize="25"
                               FontWeight="SemiBold"
                               FontFamily="Inter"
                               Foreground="#000000"
                               TextWrapping="NoWrap">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="0"
                                              BlurRadius="8"
                                              Opacity="0.15"
                                              Color="#000000"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <Border Height="3"
                            CornerRadius="2"
                            Margin="0,4,0,0"
                            HorizontalAlignment="Left"
                            Width="380"
                            Opacity="0.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2563EB" Offset="0"/>
                                <GradientStop Color="#3B82F6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <!-- Buttons block:
                     Left col:  countdown + Load Template
                     Right col: Export Summary (top) + Send Summary (bottom, same row as Load Template) -->
                <Grid Grid.Column="2" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Countdown above Load Template -->
                    <TextBlock x:Name="txtAutoSaveCountdown"
                               Grid.Row="0" Grid.Column="0"
                               Text="Automatic save in: 1:00"
                               FontSize="8"
                               FontWeight="Normal"
                               Foreground="#6B7280"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,3"/>

                    <!-- Export Summary — top right only -->
                    <Button Content="📄 Export Summary"
                            Grid.Row="0" Grid.Column="2"
                            Click="btnGenerateDocument_Click"
                            HorizontalAlignment="Stretch"
                            Padding="8,6,8,6"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Foreground="White"
                            BorderThickness="0"
                            Background="#3B82F6">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="10"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Load Template - bottom left (unchanged) -->
                    <Button Content="📂 Load Template"
                            Grid.Row="2" Grid.Column="0"
                            Click="LoadTemplateButton_Click"
                            HorizontalAlignment="Stretch"
                            Padding="8,6,8,6"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Foreground="White"
                            BorderThickness="0"
                            Background="#16A34A">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="10"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Send Summary - bottom right, same row as Load Template -->
                    <Button Content="✉️ Send Summary"
                            Grid.Row="2" Grid.Column="2"
                            Click="SendSummaryButton_Click"
                            HorizontalAlignment="Stretch"
                            Padding="8,6,8,6"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Foreground="White"
                            BorderThickness="0"
                            Background="#7C3AED">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="10"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>
            </Grid>

            <!-- Card: Configuration Content with ScrollViewer -->
            <Border Background="White" 
                    CornerRadius="12" 
                    Padding="8,16,32,32"
                    BorderThickness="0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="700">
                    <StackPanel x:Name="contentPanel">
                        <!-- Dynamic content loaded here -->
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </StackPanel>
        <Image Source="/Image1.png" Stretch="Fill"/>
    </Grid>
</Window>
