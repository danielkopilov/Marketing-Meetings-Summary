<Window x:Class="Marketing_Meetings_Summary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marketing Kickoff meeting Summary" Height="900" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Window.Resources>
        <!-- Modern Rounded Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="20" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Card Style -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="24,20" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Marketing Kickoff meeting Summary" 
                               FontSize="24" 
                               FontWeight="SemiBold" 
                               Foreground="#1E293B"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📄 Export Summary" 
                            Style="{StaticResource ModernButton}"
                            Click="btnGenerateDocument_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="24">
            <!-- Tabs -->
            <TabControl x:Name="mainTabs" 
                        BorderThickness="0" Background="Transparent">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Border" 
                                            Background="White" 
                                            BorderThickness="1,1,1,0"
                                            BorderBrush="#E2E8F0"
                                            CornerRadius="12,12,0,0"
                                            Padding="16,10"
                                            Margin="0,0,4,0">
                                        <ContentPresenter ContentSource="Header" 
                                                        HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="White"/>
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#3B82F6"/>
                                            <Setter TargetName="Border" Property="BorderThickness" Value="0,2,0,0"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Setter Property="Foreground" Value="#475569"/>
                    </Style>
                </TabControl.Resources>

                <!-- Overview Tab -->
                <TabItem Header="📋 Overview">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Style="{StaticResource ModernCard}">
                            <StackPanel>
                                <TextBlock Text="Meeting Information" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,16"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="400"/>
                                        <ColumnDefinition Width="400"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Column 0 -->
                                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,0">
                                        <TextBlock Text="Order Number *" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                        <TextBox x:Name="txtOrderNumber" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,8,0">
                                        <TextBlock Text="Customer" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                        <TextBox x:Name="txtCustomerName" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,8,0">
                                        <TextBlock Text="Final Customer" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                        <TextBox x:Name="txtFinalCustomer" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,0,8,0">
                                        <TextBlock Text="System / Project Type" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                        <TextBox x:Name="txtProjectType" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="4" Margin="0,0,8,0">
                                        <TextBlock Text="PAKA" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                        <TextBox x:Name="txtPakaNumber" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>

                                    <!-- Column 1 -->
                                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="8,0,0,0">
                                        <TextBlock Text="Meeting Date" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                        <DatePicker x:Name="dpMeetingDate" Margin="0,4,0,8"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="8,0,0,0">
                                        <TextBlock Text="Delivery Date" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                        <DatePicker x:Name="dpDeliveryDate" Margin="0,4,0,8"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Grid.Row="2" Margin="8,0,0,0">
                                        <TextBlock Text="Design Due Date" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                        <DatePicker x:Name="dpDesignDueDate" Margin="0,4,0,8"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Grid.Row="3" Margin="8,0,0,0">
                                        <TextBlock Text="Participants" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                        <TextBox x:Name="txtParticipants" Style="{StaticResource ModernTextBox}" Text="Marketing, Engineering, PM"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Grid.Row="4" Margin="8,0,0,0">
                                        <TextBlock Text="Reference Order" FontSize="13" FontWeight="Medium" Foreground="#475569"/>
                                        <TextBox x:Name="txtReferenceOrder" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <!-- Configuration Tab -->
                <TabItem Header="⚙️ Configuration">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Style="{StaticResource ModernCard}">
                            <StackPanel>
                                <TextBlock Text="System Configuration" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,16"/>

                                <ItemsControl x:Name="configItemsControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>

                                <TextBlock Text="Additional Configuration Details" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,16,0,4"/>
                                <TextBox x:Name="txtCustomConfig" 
                                         Height="120" 
                                         TextWrapping="Wrap" 
                                         AcceptsReturn="True" 
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource ModernTextBox}"
                                        />
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <!-- Targets Tab -->
                <TabItem Header="🎯 Targets">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Style="{StaticResource ModernCard}">
                            <StackPanel>
                                <TextBlock Text="Targets Definition" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,16"/>

                                <ItemsControl x:Name="targetsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Grid.Column="0" Text="{Binding Type}" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Column="1" Text="{Binding Qty}" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Column="2" Text="{Binding Details}" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>
                                                    <Button Grid.Column="3" Content="🗑" 
                                                            Background="#EF4444" 
                                                            Style="{StaticResource ModernButton}"
                                                            Padding="12,8"
                                                            Click="RemoveTarget_Click"
                                                            Tag="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="+ Add Target" 
                                        Style="{StaticResource ModernButton}" 
                                        Background="#10B981"
                                        HorizontalAlignment="Left"
                                        Margin="0,8,0,0"
                                        Click="AddTarget_Click"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <!-- Actions Tab -->
                <TabItem Header="❗ Actions">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Style="{StaticResource ModernCard}">
                            <StackPanel>
                                <TextBlock Text="Open Questions" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,12"/>

                                <ItemsControl x:Name="questionsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource ModernTextBox}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="+ Add Question" 
                                        Style="{StaticResource ModernButton}" 
                                        Background="#10B981"
                                        HorizontalAlignment="Left"
                                        Margin="0,8,0,0"
                                        Click="AddQuestion_Click"/>

                                <Rectangle Height="1" Fill="#E2E8F0" Margin="0,24"/>

                                <TextBlock Text="Action Items" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,12"/>

                                <TextBox x:Name="txtActions" 
                                         Height="150" 
                                         TextWrapping="Wrap" 
                                         AcceptsReturn="True" 
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource ModernTextBox}"
                                        />
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <!-- Notes Tab -->
                <TabItem Header="📝 Notes">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Style="{StaticResource ModernCard}">
                            <StackPanel>
                                <TextBlock Text="Meeting Summary" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtMeetingSummary" 
                                         Height="100" 
                                         TextWrapping="Wrap" 
                                         AcceptsReturn="True" 
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource ModernTextBox}"
                                        />

                                <TextBlock Text="Key Decisions" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,8,0,4"/>
                                <TextBox x:Name="txtDecisions" 
                                         Height="100" 
                                         TextWrapping="Wrap" 
                                         AcceptsReturn="True" 
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource ModernTextBox}"
                                        />

                                <TextBlock Text="Risks / Special Requirements" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,8,0,4"/>
                                <TextBox x:Name="txtRisks" 
                                         Height="100" 
                                         TextWrapping="Wrap" 
                                         AcceptsReturn="True" 
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource ModernTextBox}"
                                        />

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Logistics" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtLogistics" 
                                                 Height="80" 
                                                 TextWrapping="Wrap" 
                                                 AcceptsReturn="True" 
                                                 VerticalScrollBarVisibility="Auto"
                                                 Style="{StaticResource ModernTextBox}"
                                                />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="4,0">
                                        <TextBlock Text="Software / FG / CTE" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtSoftware" 
                                                 Height="80" 
                                                 TextWrapping="Wrap" 
                                                 AcceptsReturn="True" 
                                                 VerticalScrollBarVisibility="Auto"
                                                 Style="{StaticResource ModernTextBox}"
                                                />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                        <TextBlock Text="Installation / Training" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtTraining" 
                                                 Height="80" 
                                                 TextWrapping="Wrap" 
                                                 AcceptsReturn="True" 
                                                 VerticalScrollBarVisibility="Auto"
                                                 Style="{StaticResource ModernTextBox}"
                                                />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
