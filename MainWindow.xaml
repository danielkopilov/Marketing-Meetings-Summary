<Window x:Class="Marketing_Meetings_Summary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marketing Kickoff meeting Summary" Height="900" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Window.Resources>
        <!-- Modern Rounded Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="16" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Card Style -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Side Menu with Logo -->
        <Border Grid.Column="0" 
                Background="White" 
                CornerRadius="12" 
                Padding="16"
                Margin="0,0,16,0"
                BorderThickness="1"
                BorderBrush="#E2E8F0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.08" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <!-- Logo at top of side menu -->
                <Border Height="60" Margin="0,0,0,24" HorizontalAlignment="Center">
                    <Image Source="logo.png" Height="60" Stretch="Uniform"/>
                </Border>

                <!-- Overview Menu Item -->
                <Button x:Name="btnOverview"
                        Click="NavigateToSection"
                        Tag="0"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="10,8"
                        Margin="0,0,0,6"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏠" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Order Overview" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Configuration Menu Item -->
                <Button x:Name="btnConfiguration"
                        Click="NavigateToSection"
                        Tag="1"
                        Background="Transparent"
                        Foreground="#64748B"
                        BorderThickness="0"
                        Padding="10,8"
                        Margin="0,0,0,6"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Configuration" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Targets Menu Item -->
                <Button x:Name="btnTargets"
                        Click="NavigateToSection"
                        Tag="2"
                        Background="Transparent"
                        Foreground="#64748B"
                        BorderThickness="0"
                        Padding="10,8"
                        Margin="0,0,0,6"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎯" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Targets List" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Actions Menu Item -->
                <Button x:Name="btnActions"
                        Click="NavigateToSection"
                        Tag="3"
                        Background="Transparent"
                        Foreground="#64748B"
                        BorderThickness="0"
                        Padding="10,8"
                        Margin="0,0,0,6"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Questions" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Notes Menu Item -->
                <Button x:Name="btnNotes"
                        Click="NavigateToSection"
                        Tag="4"
                        Background="Transparent"
                        Foreground="#64748B"
                        BorderThickness="0"
                        Padding="10,8"
                        Margin="0,0,0,6"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Notes" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- Right Content Area - Two Separate Cards -->
        <StackPanel Grid.Column="1">
            <!-- Title and Export Button (No white card - on background) -->
            <Grid Margin="24,8,24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="titleText"
                               Text="Marketing Kickoff Meeting Summary" 
                               FontSize="28" 
                               FontWeight="SemiBold"
                               FontFamily="Inter"
                               Foreground="#000000">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="0" 
                                              BlurRadius="8" 
                                              Opacity="0.15" 
                                              Color="#000000"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <Border Height="3" 
                            CornerRadius="2" 
                            Margin="0,4,0,0"
                            HorizontalAlignment="Left"
                            Width="500"
                            Opacity="0.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2563EB" Offset="0"/>
                                <GradientStop Color="#3B82F6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <Button Grid.Column="1" 
                        Content="📄 Export Summary" 
                        Style="{StaticResource ModernButton}"
                        Click="btnGenerateDocument_Click"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- Card: Configuration Content with ScrollViewer -->
            <Border Background="White" 
                    CornerRadius="12" 
                    Padding="8,16,32,32"
                    BorderThickness="0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="700">
                    <StackPanel x:Name="contentPanel">
                        <!-- Dynamic content loaded here -->
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Grid>
</Window>
